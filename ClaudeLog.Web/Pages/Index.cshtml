@page
@model IndexModel
@{
    ViewData["Title"] = "ClaudeLog - Conversation Browser";
}

<div class="container-fluid p-0" style="height: 100vh; display: flex; flex-direction: column;">
    <!-- Top Bar -->
    <div class="search-bar px-3 py-2 border-bottom">
        <div class="d-flex gap-2 align-items-center">
            <button id="toggleLeftPanel" class="btn btn-outline-secondary btn-sm" title="Toggle sidebar (Ctrl+B)">☰</button>
            <a href="/" class="app-brand text-decoration-none me-2">
                <span class="brand-claude">Claude</span><span class="brand-log">Log</span>
                <span class="brand-subtitle">AI Conversation Browser</span>
            </a>
            <input type="text" id="searchInput" class="form-control" placeholder="Search conversations..." style="flex: 1;" />
            <button id="clearSearch" class="btn btn-secondary btn-sm">Clear</button>
            <a href="/api/export/core" class="btn btn-outline-secondary btn-sm">Export</a>
            <input type="file" id="importCoreFile" accept=".json,application/json" class="d-none" />
            <button id="importCoreButton" class="btn btn-outline-secondary btn-sm">Import</button>
            <a href="/Logs" class="btn btn-outline-secondary btn-sm">Logs</a>
        </div>
    </div>

    <!-- Two-Pane Layout -->
    <div class="d-flex flex-grow-1 overflow-hidden">
        <!-- Left Panel: Question List -->
        <div id="leftPanel" class="conversation-list border-end" style="width: 400px; min-width: 200px; flex-shrink: 0; overflow-y: auto; overflow-x: auto;">
            <!-- Filters -->
            <div class="p-2 border-bottom bg-light">
                <div class="d-flex gap-3 small">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="showDeleted" onchange="applyFilters()">
                        <label class="form-check-label" for="showDeleted">Show Deleted</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="showFavoritesOnly" onchange="applyFilters()">
                        <label class="form-check-label" for="showFavoritesOnly">Favorites Only</label>
                    </div>
                </div>
            </div>
            <div id="entriesList" class="p-2">
                <div class="text-center text-muted p-4">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
            <div id="loadMore" class="text-center p-3" style="display: none;">
                <button class="btn btn-outline-primary" onclick="loadMoreEntries()">Load More</button>
            </div>
        </div>

        <!-- Resize Handle -->
        <div id="resizeHandle" class="resize-handle"></div>

        <!-- Right Panel: Detail View -->
        <div class="conversation-detail flex-grow-1 p-4" style="min-width: 0; overflow-y: auto; overflow-x: auto;">
            <div id="detailView">
                <div class="text-center text-muted p-5">
                    <h4>Select a conversation to view details</h4>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="importSummaryModal" tabindex="-1" aria-labelledby="importSummaryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="importSummaryModalLabel">Import Summary</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <pre id="importSummaryContent" class="mb-0" style="white-space: pre-wrap;"></pre>
            </div>
        </div>
    </div>
</div>

